# ── Aurix AI Environment Variables ────────────────────────────────────────────

# Mistral API Key (required for summarisation, extraction, and RAG)
MISTRAL_API_KEY=your_mistral_api_key_here

# Sarvam API Key (required only for Hinglish transcription)
SARVAM_API_KEY=your_sarvam_api_key_here

# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL=small

# Google OAuth Client ID (optional — guest mode works without it)
GOOGLE_CLIENT_ID=

# Flask Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
FLASK_SECRET_KEY=change-this-to-a-random-secret-in-production
